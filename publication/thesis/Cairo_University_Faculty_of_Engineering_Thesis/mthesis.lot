\contentsline {table}{\numberline {\if@rl \I {1.3}\else \textLR {3.1}\fi }{\ignorespaces Fields in the inference JSONL files. All fields from the export stage are preserved through inference; the \texttt {correction} and status fields are appended by the inference script.}}{\if@rlmain \I {41}\else \textLR {41}\fi }{table.caption.3}%
\contentsline {table}{\numberline {\if@rl \I {2.3}\else \textLR {3.2}\fi }{\ignorespaces Dataset summary. All PATS-A01 fonts share the same aligned split (415 validation / 2,351 training samples). KHATT sample counts depend on writer structure. The four new datasets provide validation/testing splits only (no training-split OCR). All validation and testing splits are evaluated in Experiment~2.}}{\if@rlmain \I {48}\else \textLR {48}\fi }{table.caption.4}%
\contentsline {table}{\numberline {\if@rl \I {3.3}\else \textLR {3.3}\fi }{\ignorespaces Error taxonomy used in Phase~1 baseline analysis. Categories are ordered from most specific (dot confusion) to most general (other substitution).}}{\if@rlmain \I {52}\else \textLR {52}\fi }{table.caption.5}%
\contentsline {table}{\numberline {\if@rl \I {4.3}\else \textLR {3.4}\fi }{\ignorespaces Generation parameters for \texttt {TransformersCorrector}.}}{\if@rlmain \I {58}\else \textLR {58}\fi }{table.caption.7}%
\contentsline {table}{\numberline {\if@rl \I {5.3}\else \textLR {3.5}\fi }{\ignorespaces Prompt variant registry. Each phase uses exactly one variant. All prompts are in Arabic. Full prompt text is given in Appendix~A. Phase~5 (CAMeL post-processing) applies no new prompt: it uses the Phase~2 zero-shot prompt and post-processes the LLM output with the morphological validator.}}{\if@rlmain \I {60}\else \textLR {60}\fi }{table.caption.8}%
\addvspace {10\p@ }
\contentsline {table}{\numberline {\if@rl \I {1.4}\else \textLR {4.1}\fi }{\ignorespaces Phase~4 training-split analysis results (PATS-A01 aggregate). Fix rate = fraction of baseline errors of that type corrected by the LLM. Introduction rate = fraction of correct ground-truth tokens of that type incorrectly changed. $\dagger $ = fewer than 10 baseline samples (estimate unreliable).}}{\if@rlmain \I {74}\else \textLR {74}\fi }{table.caption.9}%
\contentsline {table}{\numberline {\if@rl \I {2.4}\else \textLR {4.2}\fi }{\ignorespaces Summary of all experimental phases. ``Comparison'' is the phase each experiment is evaluated against. All phases are evaluated across nine datasets (eight PATS-A01 fonts + KHATT validation split).}}{\if@rlmain \I {86}\else \textLR {86}\fi }{table.caption.10}%
\contentsline {table}{\numberline {\if@rl \I {3.4}\else \textLR {4.3}\fi }{\ignorespaces Experiment~2 trial definitions. Each trial is a unique combination of prompt style (A), example set (B), and retrieval strategy (C).}}{\if@rlmain \I {89}\else \textLR {89}\fi }{table.caption.11}%
\addvspace {10\p@ }
\contentsline {table}{\numberline {\if@rl \I {1.5}\else \textLR {5.1}\fi }{\ignorespaces Phase~1 Qaari OCR baseline metrics per dataset (validation split, diacritics stripped). Fonts ordered by increasing mean CER. CER Median and P95 characterise within-dataset variation.}}{\if@rlmain \I {94}\else \textLR {94}\fi }{table.caption.12}%
\contentsline {table}{\numberline {\if@rl \I {2.5}\else \textLR {5.2}\fi }{\ignorespaces Phase~1 error type distribution (\% of total errors). PATS-A01 aggregate across all eight fonts. Dot confusion dominates typewritten fonts; KHATT shows a more diverse profile with substantial segmentation errors.}}{\if@rlmain \I {95}\else \textLR {95}\fi }{table.caption.13}%
\contentsline {table}{\numberline {\if@rl \I {3.5}\else \textLR {5.3}\fi }{\ignorespaces Top-10 character confusion pairs across all eight PATS-A01 fonts (training split, aggregate). gt = ground-truth character; ocr = OCR output character. Count = total substitution instances. Conf.\ rate = P(ocr | gt).}}{\if@rlmain \I {96}\else \textLR {96}\fi }{table.caption.14}%
\contentsline {table}{\numberline {\if@rl \I {4.5}\else \textLR {5.4}\fi }{\ignorespaces Morphological validity of OCR error tokens (Phase~1). Non-word = zero CAMeL analyses; Valid-but-wrong = at least one valid analysis, contextually incorrect. PATS-A01: aggregate.}}{\if@rlmain \I {96}\else \textLR {96}\fi }{table.caption.15}%
\contentsline {table}{\numberline {\if@rl \I {5.5}\else \textLR {5.5}\fi }{\ignorespaces Phase~2 zero-shot LLM correction vs.\ Phase~1 OCR baseline (validation split, diacritics stripped). $\Delta $CER (pp) = absolute change in percentage points; negative = improvement.}}{\if@rlmain \I {98}\else \textLR {98}\fi }{table.caption.16}%
\contentsline {table}{\numberline {\if@rl \I {6.5}\else \textLR {5.6}\fi }{\ignorespaces Phase~2 per-font error fix and introduction rates (validation split). Fix rate = proportion of Phase~1 errors corrected by LLM. Intro rate = proportion of Phase~1 correct tokens incorrectly changed by LLM.}}{\if@rlmain \I {99}\else \textLR {99}\fi }{table.caption.17}%
\contentsline {table}{\numberline {\if@rl \I {7.5}\else \textLR {5.7}\fi }{\ignorespaces PATS-A01 macro-average CER/WER for all phases (validation split, diacritics stripped). $\Delta $CER is vs.\ Phase~2 in percentage points. Best LLM phase in \textbf {bold}.}}{\if@rlmain \I {100}\else \textLR {100}\fi }{table.caption.18}%
\contentsline {table}{\numberline {\if@rl \I {8.5}\else \textLR {5.8}\fi }{\ignorespaces Phase~3 OCR-Aware vs.\ Phase~2 zero-shot, per font (validation split, diacritics stripped). $\downarrow $ = improvement vs P2, $\uparrow $ = degradation.}}{\if@rlmain \I {101}\else \textLR {101}\fi }{table.caption.19}%
\contentsline {table}{\numberline {\if@rl \I {9.5}\else \textLR {5.9}\fi }{\ignorespaces Phase~4 Self-Reflective vs.\ Phase~2 zero-shot, per font (validation split, diacritics stripped).}}{\if@rlmain \I {102}\else \textLR {102}\fi }{table.caption.20}%
\contentsline {table}{\numberline {\if@rl \I {10.5}\else \textLR {5.10}\fi }{\ignorespaces Phase~5 CAMeL post-processing vs.\ Phase~2 zero-shot, per font. Revert rate = fraction of changed words reverted to OCR original.}}{\if@rlmain \I {103}\else \textLR {103}\fi }{table.caption.21}%
\contentsline {table}{\numberline {\if@rl \I {11.5}\else \textLR {5.11}\fi }{\ignorespaces Per-font CER (\%) for Phases~1--5 and Phase~8 (validation split, diacritics stripped). Best LLM result per font in \textbf {bold}. $\downarrow $ cells indicate improvement vs Phase~2. P8 values marked with $\dagger $ are preliminary; verify with final results.}}{\if@rlmain \I {104}\else \textLR {104}\fi }{table.caption.22}%
\contentsline {table}{\numberline {\if@rl \I {12.5}\else \textLR {5.12}\fi }{\ignorespaces Phase~6 combination results: PATS-A01 macro-average and KHATT CER (validation split, diacritics stripped). $\Delta $CER vs.\ Phase~2 in percentage points. Best combination per column in \textbf {bold}.}}{\if@rlmain \I {105}\else \textLR {105}\fi }{table.caption.23}%
\contentsline {table}{\numberline {\if@rl \I {13.5}\else \textLR {5.13}\fi }{\ignorespaces Per-font CER (\%) for Phase~6 combinations vs.\ Phase~2 baseline (validation split, diacritics stripped). Best result per font in \textbf {bold}.}}{\if@rlmain \I {106}\else \textLR {106}\fi }{table.caption.24}%
\contentsline {table}{\numberline {\if@rl \I {14.5}\else \textLR {5.14}\fi }{\ignorespaces Phase~6 ablation results: CER when removing each component from \texttt {conf\_self} (PATS-A01 macro-average, diacritics stripped). Positive $\Delta $CER vs.\ Full = component was helping.}}{\if@rlmain \I {106}\else \textLR {106}\fi }{table.caption.25}%
\contentsline {table}{\numberline {\if@rl \I {15.5}\else \textLR {5.15}\fi }{\ignorespaces Statistical significance: \texttt {conf\_self} vs.\ Phase~2 (paired t-test, per-sample CER). Cohen's $d$ = effect size. Bonferroni-corrected threshold: $\alpha = 0.0125$ (4 comparisons). $^{*}$ = significant at Bonferroni-corrected $\alpha $.}}{\if@rlmain \I {107}\else \textLR {107}\fi }{table.caption.26}%
\contentsline {table}{\numberline {\if@rl \I {16.5}\else \textLR {5.16}\fi }{\ignorespaces Phase~8 RAG (BM25) vs.\ Phase~2 zero-shot, per font (validation split, diacritics stripped). $\downarrow $ = improvement, $\uparrow $ = degradation vs.\ P2. \dag ~values are preliminary; verify with final pipeline run.}}{\if@rlmain \I {108}\else \textLR {108}\fi }{table.caption.27}%
\contentsline {table}{\numberline {\if@rl \I {17.5}\else \textLR {5.17}\fi }{\ignorespaces Final ranking of all experimental conditions by PATS-A01 macro-average CER (validation split, diacritics stripped). Lower CER is better. Phase~1 is included as the OCR reference.}}{\if@rlmain \I {109}\else \textLR {109}\fi }{table.caption.28}%
\contentsline {table}{\numberline {\if@rl \I {18.5}\else \textLR {5.18}\fi }{\ignorespaces Phase~1 OCR baseline metrics for the four new full-page datasets (testing/validation split, diacritics stripped).}}{\if@rlmain \I {111}\else \textLR {111}\fi }{table.caption.29}%
\contentsline {table}{\numberline {\if@rl \I {19.5}\else \textLR {5.19}\fi }{\ignorespaces Experiment~2 trial CER (\%) on the four new full-page datasets (diacritics stripped). T1--T8 as defined in Table~\ref {tab:exp2_trials}. Lower is better. Best trial per dataset in \textbf {bold}. All values \tbd {} pending inference.}}{\if@rlmain \I {111}\else \textLR {111}\fi }{table.caption.30}%
\contentsline {table}{\numberline {\if@rl \I {20.5}\else \textLR {5.20}\fi }{\ignorespaces Best Experiment~2 trial vs.\ best Experiment~1 result on the nine established datasets (PATS-A01 macro-average and KHATT). All values \tbd {} pending inference.}}{\if@rlmain \I {112}\else \textLR {112}\fi }{table.caption.31}%
\contentsline {table}{\numberline {\if@rl \I {21.5}\else \textLR {5.21}\fi }{\ignorespaces Experiment~2 estimated main effects on mean CER across the four new datasets. A negative value indicates the factor level reduces CER relative to the other level. All values \tbd {} pending inference.}}{\if@rlmain \I {112}\else \textLR {112}\fi }{table.caption.32}%
