\contentsline {table}{\numberline {\if@rl \I {1.3}\else \textLR {3.1}\fi }{\ignorespaces Fields in the inference JSONL files. All fields from the export stage are preserved through inference; the \texttt {correction} and status fields are appended by the inference script.}}{\if@rlmain \I {43}\else \textLR {43}\fi }{table.caption.3}%
\contentsline {table}{\numberline {\if@rl \I {2.3}\else \textLR {3.2}\fi }{\ignorespaces Dataset summary. All PATS-A01 fonts share the same aligned split (415 validation / 2,351 training samples). KHATT sample counts depend on writer structure. All validation splits are evaluated across all experimental phases.}}{\if@rlmain \I {47}\else \textLR {47}\fi }{table.caption.4}%
\contentsline {table}{\numberline {\if@rl \I {3.3}\else \textLR {3.3}\fi }{\ignorespaces Error taxonomy used in Phase~1 baseline analysis. Categories are ordered from most specific (dot confusion) to most general (other substitution).}}{\if@rlmain \I {51}\else \textLR {51}\fi }{table.caption.5}%
\contentsline {table}{\numberline {\if@rl \I {4.3}\else \textLR {3.4}\fi }{\ignorespaces Generation parameters for \texttt {TransformersCorrector}.}}{\if@rlmain \I {56}\else \textLR {56}\fi }{table.caption.7}%
\contentsline {table}{\numberline {\if@rl \I {5.3}\else \textLR {3.5}\fi }{\ignorespaces Prompt variant registry. Each phase uses exactly one variant. All prompts are in Arabic. Full prompt text is given in Appendix~A. Phase~5 (CAMeL post-processing) applies no new prompt: it uses the Phase~2 zero-shot prompt and post-processes the LLM output with the morphological validator.}}{\if@rlmain \I {59}\else \textLR {59}\fi }{table.caption.8}%
\addvspace {10\p@ }
\contentsline {table}{\numberline {\if@rl \I {1.4}\else \textLR {4.1}\fi }{\ignorespaces Phase~4 training-split analysis results (PATS-A01 aggregate). Fix rate = fraction of baseline errors of that type corrected by the LLM. Introduction rate = fraction of correct ground-truth tokens of that type incorrectly changed. $\dagger $ = fewer than 10 baseline samples (estimate unreliable).}}{\if@rlmain \I {72}\else \textLR {72}\fi }{table.caption.9}%
\contentsline {table}{\numberline {\if@rl \I {2.4}\else \textLR {4.2}\fi }{\ignorespaces Summary of all experimental phases. ``Comparison'' is the phase each experiment is evaluated against. All phases are evaluated across nine datasets (eight PATS-A01 fonts + KHATT validation split).}}{\if@rlmain \I {81}\else \textLR {81}\fi }{table.caption.10}%
\addvspace {10\p@ }
\contentsline {table}{\numberline {\if@rl \I {1.5}\else \textLR {5.1}\fi }{\ignorespaces Phase~1 Qaari OCR baseline metrics per dataset (validation split, diacritics stripped). Fonts ordered by increasing mean CER. CER Median and P95 characterise within-dataset variation.}}{\if@rlmain \I {84}\else \textLR {84}\fi }{table.caption.11}%
\contentsline {table}{\numberline {\if@rl \I {2.5}\else \textLR {5.2}\fi }{\ignorespaces Phase~1 error type distribution (\% of total errors). PATS-A01 aggregate across all eight fonts. Dot confusion dominates typewritten fonts; KHATT shows a more diverse profile with substantial segmentation errors.}}{\if@rlmain \I {85}\else \textLR {85}\fi }{table.caption.12}%
\contentsline {table}{\numberline {\if@rl \I {3.5}\else \textLR {5.3}\fi }{\ignorespaces Top-10 character confusion pairs across all eight PATS-A01 fonts (training split, aggregate). gt = ground-truth character; ocr = OCR output character. Count = total substitution instances. Conf.\ rate = P(ocr | gt).}}{\if@rlmain \I {86}\else \textLR {86}\fi }{table.caption.13}%
\contentsline {table}{\numberline {\if@rl \I {4.5}\else \textLR {5.4}\fi }{\ignorespaces Morphological validity of OCR error tokens (Phase~1). Non-word = zero CAMeL analyses; Valid-but-wrong = at least one valid analysis, contextually incorrect. PATS-A01: aggregate.}}{\if@rlmain \I {86}\else \textLR {86}\fi }{table.caption.14}%
\contentsline {table}{\numberline {\if@rl \I {5.5}\else \textLR {5.5}\fi }{\ignorespaces Phase~2 zero-shot LLM correction vs.\ Phase~1 OCR baseline (validation split, diacritics stripped). $\Delta $CER (pp) = absolute change in percentage points; negative = improvement.}}{\if@rlmain \I {88}\else \textLR {88}\fi }{table.caption.15}%
\contentsline {table}{\numberline {\if@rl \I {6.5}\else \textLR {5.6}\fi }{\ignorespaces Phase~2 per-font error fix and introduction rates (validation split). Fix rate = proportion of Phase~1 errors corrected by LLM. Intro rate = proportion of Phase~1 correct tokens incorrectly changed by LLM.}}{\if@rlmain \I {89}\else \textLR {89}\fi }{table.caption.16}%
\contentsline {table}{\numberline {\if@rl \I {7.5}\else \textLR {5.7}\fi }{\ignorespaces PATS-A01 macro-average CER/WER for all phases (validation split, diacritics stripped). $\Delta $CER is vs.\ Phase~2 in percentage points. Best LLM phase in \textbf {bold}.}}{\if@rlmain \I {90}\else \textLR {90}\fi }{table.caption.17}%
\contentsline {table}{\numberline {\if@rl \I {8.5}\else \textLR {5.8}\fi }{\ignorespaces Phase~3 OCR-Aware vs.\ Phase~2 zero-shot, per font (validation split, diacritics stripped). $\downarrow $ = improvement vs P2, $\uparrow $ = degradation.}}{\if@rlmain \I {91}\else \textLR {91}\fi }{table.caption.18}%
\contentsline {table}{\numberline {\if@rl \I {9.5}\else \textLR {5.9}\fi }{\ignorespaces Phase~4 Self-Reflective vs.\ Phase~2 zero-shot, per font (validation split, diacritics stripped).}}{\if@rlmain \I {92}\else \textLR {92}\fi }{table.caption.19}%
\contentsline {table}{\numberline {\if@rl \I {10.5}\else \textLR {5.10}\fi }{\ignorespaces Phase~5 CAMeL post-processing vs.\ Phase~2 zero-shot, per font. Revert rate = fraction of changed words reverted to OCR original.}}{\if@rlmain \I {93}\else \textLR {93}\fi }{table.caption.20}%
\contentsline {table}{\numberline {\if@rl \I {11.5}\else \textLR {5.11}\fi }{\ignorespaces Per-font CER (\%) for Phases~1--5 (validation split, diacritics stripped). Best LLM result per font in \textbf {bold}. $\downarrow $ cells indicate improvement vs Phase~2.}}{\if@rlmain \I {94}\else \textLR {94}\fi }{table.caption.21}%
\contentsline {table}{\numberline {\if@rl \I {12.5}\else \textLR {5.12}\fi }{\ignorespaces Phase~6 combination results: PATS-A01 macro-average and KHATT CER (validation split, diacritics stripped). $\Delta $CER vs.\ Phase~2 in percentage points. Best combination per column in \textbf {bold}.}}{\if@rlmain \I {95}\else \textLR {95}\fi }{table.caption.22}%
\contentsline {table}{\numberline {\if@rl \I {13.5}\else \textLR {5.13}\fi }{\ignorespaces Per-font CER (\%) for Phase~6 combinations vs.\ Phase~2 baseline (validation split, diacritics stripped). Best result per font in \textbf {bold}.}}{\if@rlmain \I {96}\else \textLR {96}\fi }{table.caption.23}%
\contentsline {table}{\numberline {\if@rl \I {14.5}\else \textLR {5.14}\fi }{\ignorespaces Phase~6 ablation results: CER when removing each component from \texttt {conf\_self} (PATS-A01 macro-average, diacritics stripped). Positive $\Delta $CER vs.\ Full = component was helping.}}{\if@rlmain \I {97}\else \textLR {97}\fi }{table.caption.24}%
\contentsline {table}{\numberline {\if@rl \I {15.5}\else \textLR {5.15}\fi }{\ignorespaces Statistical significance: \texttt {conf\_self} vs.\ Phase~2 (paired t-test, per-sample CER). Cohen's $d$ = effect size. Bonferroni-corrected threshold: $\alpha = 0.0125$ (4 comparisons). $^{*}$ = significant at Bonferroni-corrected $\alpha $.}}{\if@rlmain \I {97}\else \textLR {97}\fi }{table.caption.25}%
\contentsline {table}{\numberline {\if@rl \I {16.5}\else \textLR {5.16}\fi }{\ignorespaces Final ranking of all experimental conditions by PATS-A01 macro-average CER (validation split, diacritics stripped). Lower CER is better. Phase~1 is included as the OCR reference.}}{\if@rlmain \I {98}\else \textLR {98}\fi }{table.caption.26}%
