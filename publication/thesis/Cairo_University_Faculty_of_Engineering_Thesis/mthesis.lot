\contentsline {table}{\numberline {\if@rl \I {1.3}\else \textLR {3.1}\fi }{\ignorespaces Fields in the inference JSONL files. All fields from the export stage are preserved through inference; the \texttt {correction} and status fields are appended by the inference script.}}{\if@rlmain \I {35}\else \textLR {35}\fi }{table.caption.3}%
\contentsline {table}{\numberline {\if@rl \I {2.3}\else \textLR {3.2}\fi }{\ignorespaces Dataset summary. ``Evaluated'' is the number of samples used in experiments reported in this thesis. ``---'' indicates that statistics depend on writer count and session structure not yet fully catalogued.}}{\if@rlmain \I {39}\else \textLR {39}\fi }{table.caption.4}%
\contentsline {table}{\numberline {\if@rl \I {3.3}\else \textLR {3.3}\fi }{\ignorespaces Error taxonomy used in Phase~1 baseline analysis. Categories are ordered from most specific (dot confusion) to most general (other substitution).}}{\if@rlmain \I {42}\else \textLR {42}\fi }{table.caption.5}%
\contentsline {table}{\numberline {\if@rl \I {4.3}\else \textLR {3.4}\fi }{\ignorespaces Arabic orthographic rule categories used in Phase~4A. Each category targets a specific phenomenon that both human writers and OCR engines commonly mishandle.}}{\if@rlmain \I {44}\else \textLR {44}\fi }{table.caption.6}%
